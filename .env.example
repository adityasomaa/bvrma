# =========================
# Server-only — NEVER commit values
# Set these directly in Vercel env (Production + Preview + Development)
# =========================

# Sanity write token (Editor permission). Generate at sanity.io/manage > API > Tokens.
SANITY_API_WRITE_TOKEN=

# Supabase service role (admin). Treat like a master password.
SUPABASE_SERVICE_ROLE_KEY=

# Supabase Postgres connection string (for migrations).
SUPABASE_DB_URL=postgres://postgres:PASSWORD@db.xoipxnvbzhlftplszpyc.supabase.co:5432/postgres

# Resend (email). Get at resend.com/api-keys
RESEND_API_KEY=
RESEND_FROM_EMAIL=BVRMA <hello@bvrma.org>
RESEND_TO_EMAIL=info@bvrma.org

# Optional: revalidation secret for Sanity webhooks
SANITY_REVALIDATE_SECRET=
